{
  "//": "======================================================================",
  "//": " Claude Code 配置文件模板",
  "//": " 将此文件复制到 ~/.claude/settings.json 并根据需要修改",
  "//": "======================================================================",

  "apiKey": "你的真实API-Key",
  "model": "deepseek-chat",
  "apiBaseUrl": "https://api.deepseek.com/v1",

  "//": "可选配置项",
  "maxTokens": 4096,
  "temperature": 0.7,

  "//": "代理配置（如需要）",
  "proxy": {
    "http": "",
    "https": ""
  },

  "//": "MCP 服务器配置",
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": ""
      }
    }
  }
}
